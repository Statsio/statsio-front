    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Login success is true\", function () {",
                  "    pm.expect(res.success).to.eql(true);",
                  "});",
                  "",
                  "if (res.success && res.data) {",
                  "    pm.environment.set(\"token\", res.data.access_token || res.data.token || \"\");",
                  "    pm.environment.set(\"token_type\", res.data.type || \"Bearer\");",
                  "    pm.environment.set(\"refresh_token\", res.data.refresh_token || \"\");",
                  "    pm.environment.set(\"user_id\", res.data.user?.id || \"\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{language}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
